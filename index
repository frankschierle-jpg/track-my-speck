// ── Color picker ──
let colorDragging = false;
const SPECTRUM_COLORS = [
  [232,56,13],[245,197,24],[46,204,113],[79,195,247],[234,128,252],[255,96,64]
];
function spectrumColor(pct) {
  const n = SPECTRUM_COLORS.length - 1;
  const i = Math.floor(pct * n);
  const t = pct * n - i;
  const a = SPECTRUM_COLORS[Math.min(i,n)];
  const b = SPECTRUM_COLORS[Math.min(i+1,n)];
  const r = Math.round(a[0]+(b[0]-a[0])*t);
  const g = Math.round(a[1]+(b[1]-a[1])*t);
  const bl = Math.round(a[2]+(b[2]-a[2])*t);
  return `#${r.toString(16).padStart(2,'0')}${g.toString(16).padStart(2,'0')}${bl.toString(16).padStart(2,'0')}`;
}
window.startColorDrag = function(e) {
  colorDragging = true;
  updateColorFromEvent(e);
  document.addEventListener('mousemove', onColorMove);
  document.addEventListener('mouseup', stopColorDrag);
  document.addEventListener('touchmove', onColorMove, {passive:false});
  document.addEventListener('touchend', stopColorDrag);
};
function onColorMove(e) { if(!colorDragging) return; e.preventDefault(); updateColorFromEvent(e); }
function stopColorDrag() {
  colorDragging = false;
  document.removeEventListener('mousemove', onColorMove);
  document.removeEventListener('mouseup', stopColorDrag);
  document.removeEventListener('touchmove', onColorMove);
  document.removeEventListener('touchend', stopColorDrag);
}
function updateColorFromEvent(e) {
  const spec = document.getElementById('color-spectrum');
  const rect = spec.getBoundingClientRect();
  const clientX = e.touches ? e.touches[0].clientX : e.clientX;
  const pct = Math.max(0, Math.min(1, (clientX - rect.left) / rect.width));
  const col = spectrumColor(pct);
  document.getElementById('color-handle').style.left = (pct*100)+'%';
  document.getElementById('color-preview').style.background = col;
  document.getElementById('color-hex-lbl').textContent = col;
  const prof = getProfile(currentUser?.uid);
  prof.color = col;
  // live save
  saveProfileData(currentUser?.uid, prof);
  renderHome();
}
function setColorPickerToColor(col) {
  // Find closest pct
  let best = 0, bestDiff = Infinity;
  for(let i=0;i<=100;i++){
    const c = spectrumColor(i/100);
    const diff = colorDiff(col, c);
    if(diff < bestDiff) { bestDiff = diff; best = i/100; }
  }
  document.getElementById('color-handle').style.left = (best*100)+'%';
  document.getElementById('color-preview').style.background = col;
  document.getElementById('color-hex-lbl').textContent = col;
}
function colorDiff(a,b) {
  const pa = hexToRgb(a), pb = hexToRgb(b);
  if(!pa||!pb) return 999;
  return Math.abs(pa[0]-pb[0])+Math.abs(pa[1]-pb[1])+Math.abs(pa[2]-pb[2]);
}
function hexToRgb(h) {
  const m = h.match(/^#([0-9a-f]{6})$/i);
  if(!m) return null;
  const v = parseInt(m[1],16);
  return [(v>>16)&255,(v>>8)&255,v&255];
}

