// ── Calorie math (validated) ──
function bmr(u) {
  const kg = u.curKg || u.sKg;
  // Mifflin-St Jeor
  const base = 10*kg + 6.25*(u.h||170) - 5*(u.age||30);
  return u.gen === 'm' ? Math.round(base + 5) : Math.round(base - 161);
}
function sportKcal(u) {
  const met = {light:4,medium:6,heavy:9}[u.int] || 5;
  return Math.round(met * (u.curKg||u.sKg) * (u.sport||0) / 7);
}
function stepKcal(u) {
  return Math.round((u.steps||0) * 0.04 * (u.curKg||u.sKg) / 70);
}
function tdee(u) { return bmr(u) + sportKcal(u) + stepKcal(u); }
function deficit(u) {
  const weeks = u.weeks || 13;
  return Math.round((u.sKg - u.gKg) * 7700 / (weeks * 7));
}
function budget(u) { return Math.max(1200, tdee(u) - deficit(u)); }
function targetW(u, ts) {
  const days = Math.max(0, Math.round((new Date(ts) - new Date(u.created)) / 86400000));
  const total = (u.weeks||13) * 7;
  return parseFloat((u.sKg - (u.sKg - u.gKg) * Math.min(1, days/total)).toFixed(2));
}
function absDay(u) {
  if(u.targetDate) return new Date(u.targetDate);
  const d = new Date(u.created);
  d.setDate(d.getDate() + (u.weeks||13)*7);
  return d;
}
function weeksUntilTarget(u) {
  const d = absDay(u);
  const now = new Date();
  return Math.max(0, Math.round((d - now) / (7*86400000)));
}

// ── BMR sanity check ──
function bmrWarning(u) {
  const b = bmr(u);
  if(b < 1200) return `⚠️ Dein Grundumsatz (${b} kcal) scheint sehr niedrig. Bitte Alter, Größe, Gewicht und Geschlecht prüfen.`;
  if(b > 3500) return `⚠️ Dein Grundumsatz (${b} kcal) ist sehr hoch. Bitte Eingaben prüfen.`;
  const def = deficit(u);
  if(def > 1000) return `⚠️ Tägliches Defizit von ${def} kcal ist sehr hoch (>1000 kcal). Erwäge längeren Zeitraum oder weniger strenges Ziel.`;
  return null;
}

