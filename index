        ? `<div class="ucard-w" style="color:${col};font-size:1.4rem;font-weight:800;line-height:1.2;text-align:right">TRACKED<br><span style="font-size:0.75rem;opacity:0.6">today ✓</span></div>`
        : `<div class="ucard-w none">NICHT<br>ERFASST<br>HEUTE</div>`;
    }

    const isMyCard = u.id === myId;
    const quickRow = isMyCard ? `
      <div class="qrow" onclick="event.stopPropagation()">
        <input class="qi" type="text" inputmode="decimal" id="qi${u.id}" placeholder="Schnell Gewicht eintragen… (z.B. 82,4)" onkeydown="if(event.key==='Enter')ql('${u.id}')">
        <button class="qbtn" onclick="ql('${u.id}')">💾 Speichern</button>
      </div>` : '';

    return `<div class="ucard ${tracked?'ok':'nope'}" style="border-left-color:${col}">
      <div class="ucard-main" onclick="showUser('${u.id}')">
        <div class="ucard-l">
          <div class="ucard-n" style="color:${col}">
            <div class="ucard-avatar" style="border-color:${col};background:${col}20">${av}</div>
            ${u.name} ${trendArrow}
          </div>
          <div class="ucard-m">${metaLine}</div>
          ${tracked ? `<div class="ok-badge"><span>✅</span><div class="ok-txt">${posSlogan}</div></div>` : `<div class="nope-badge"><span>🔥</span><div class="nope-txt">${negSlogan}</div></div>`}
        </div>
