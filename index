<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getFirestore, doc, setDoc, getDocs, collection, onSnapshot } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";
import {
  getAuth, createUserWithEmailAndPassword, signInWithEmailAndPassword,
  sendEmailVerification, sendPasswordResetEmail, onAuthStateChanged, signOut
} from "https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js";

const firebaseConfig = {
  apiKey: "AIzaSyCfKzlgqZLjvQtWikRfB5xiVVOpimYUDzM",
  authDomain: "track-my-fat.firebaseapp.com",
  projectId: "track-my-fat",
  storageBucket: "track-my-fat.firebasestorage.app",
  messagingSenderId: "1256649219",
  appId: "1:1256649219:web:6f0e350ea13032f572d436"
};
const fbApp = initializeApp(firebaseConfig);
const db = getFirestore(fbApp);
const auth = getAuth(fbApp);

// ── Dark mode ──
window.toggleDark = function(){
  const d = document.body.classList.toggle('dark');
  document.getElementById('dm-btn').classList.toggle('on',d);
  document.getElementById('dm-lbl').textContent = d ? 'Dunkel' : 'Hell';
  document.getElementById('theme-color-meta').content = d ? '#080808' : '#ffffff';
  LS.set('tmf_dark', d);
};
function applyDark(on){
  document.body.classList.toggle('dark',on);
  document.getElementById('dm-btn').classList.toggle('on',on);
  document.getElementById('dm-lbl').textContent = on ? 'Dunkel' : 'Hell';
}

// ── Tab switcher ──
window.switchTab = function(tab) {
  document.getElementById('tab-login').classList.toggle('on', tab==='login');
  document.getElementById('tab-register').classList.toggle('on', tab==='register');
  document.getElementById('form-login').classList.toggle('hidden', tab!=='login');
  document.getElementById('form-register').classList.toggle('hidden', tab!=='register');
  hideErr();
};

function showErr(id, msg) {
  const el = document.getElementById(id);
  el.textContent = msg; el.style.display = 'block';
}
function showInfo(id, msg) {
  const el = document.getElementById(id);
  el.innerHTML = msg; el.style.display = 'block';
}
function hideErr() {
  ['l-err','l-info','r-err','r-info'].forEach(id => {
    const el = document.getElementById(id);
    if(el) { el.textContent=''; el.style.display='none'; }
  });
}

// ── Login ──
window.doLogin = async function() {
  hideErr();
  const email = document.getElementById('l-email').value.trim();
  const pass = document.getElementById('l-pass').value;
  if(!email || pass.length < 4) { showErr('l-err', 'Bitte E-Mail und Passwort (mind. 4 Zeichen) eingeben.'); return; }
  try {
    const cred = await signInWithEmailAndPassword(auth, email, pass);
    if(!cred.user.emailVerified) {
      await signOut(auth);
      showErr('l-err', '❗ E-Mail noch nicht bestätigt.');
      showInfo('l-info', 'Bestätigungs-E-Mail nicht erhalten? <span style="color:var(--red);cursor:pointer;text-decoration:underline" onclick="resendVerification(\''+email+'\',\''+pass+'\')">Erneut senden</span>');
    }
  } catch(e) { showErr('l-err', authErr(e.code)); }
};

window.resendVerification = async function(email, pass) {
  try {
    const cred = await signInWithEmailAndPassword(auth, email, pass);
    await sendEmailVerification(cred.user);
    await signOut(auth);
    showInfo('l-info', '✅ Bestätigungs-E-Mail erneut gesendet!');
  } catch(e) { showErr('l-err', authErr(e.code)); }
};

window.doRegister = async function() {
  hideErr();
  const email = document.getElementById('r-email').value.trim();
