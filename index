<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="apple-mobile-web-app-title" content="Track My Fat">
<meta name="theme-color" id="theme-color-meta" content="#ffffff">
<title>TMF 🔥</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=IBM+Plex+Mono:wght@400;500;600&family=Barlow:wght@300;400;500;600;700&display=swap');
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
:root{
  --bg:#f5f3ef;--bg2:#ffffff;--bg3:#ede9e3;--bg4:#e2ddd6;
  --red:#e8380d;--red2:#ff6240;
  --green:#1ea35a;--yellow:#d4a017;--blue:#2980b9;
  --text:#1a1614;--text2:#5a5450;--muted:#9a928a;
  --border:rgba(0,0,0,0.1);--border2:rgba(0,0,0,0.16);
  --card:rgba(0,0,0,0.03);
  --shadow:0 2px 12px rgba(0,0,0,0.08);
}
.dark{
  --bg:#080808;--bg2:#101010;--bg3:#181818;--bg4:#222;
  --red:#e8380d;--red2:#ff6240;
  --green:#2ecc71;--yellow:#f5c518;--blue:#4fc3f7;
  --text:#f0ece4;--text2:#b0a898;--muted:#606060;
  --border:rgba(255,255,255,0.08);--border2:rgba(255,255,255,0.14);
  --card:rgba(255,255,255,0.03);
  --shadow:0 2px 12px rgba(0,0,0,0.4);
}
html,body{background:var(--bg);color:var(--text);font-family:'Barlow',sans-serif;min-height:100vh;overflow-x:hidden;font-size:16px;transition:background 0.3s,color 0.3s}
button{font-family:'Barlow',sans-serif;cursor:pointer;border:none;background:none}
input,select{font-family:'IBM Plex Mono',monospace;outline:none;color:var(--text)}
::-webkit-scrollbar{display:none}

.scr{display:none;min-height:100vh}
.scr.on{display:block}
#scr-home.on,#scr-login.on{display:flex;flex-direction:column}

/* ── DARK MODE TOGGLE ── */
.dm-toggle{position:fixed;top:14px;right:16px;z-index:9990;display:flex;align-items:center;gap:8px}
.dm-btn{width:44px;height:24px;border-radius:12px;background:var(--bg4);border:1px solid var(--border2);position:relative;cursor:pointer;transition:background 0.25s;flex-shrink:0}
.dm-btn.on{background:#222}
.dm-btn::after{content:'';position:absolute;top:3px;left:3px;width:16px;height:16px;border-radius:50%;background:var(--red);transition:transform 0.25s;box-shadow:0 1px 4px rgba(0,0,0,0.3)}
.dm-btn.on::after{transform:translateX(20px)}
.dm-lbl{font-family:'IBM Plex Mono',monospace;font-size:0.6rem;color:var(--muted);letter-spacing:0.1em;text-transform:uppercase}

/* ── LOGO SVG (light/dark adaptive) ── */
.logo-svg .bar1{fill:var(--red);opacity:0.22}
.logo-svg .bar2{fill:var(--red);opacity:0.45}
.logo-svg .bar3{fill:var(--red);opacity:0.72}
.logo-svg .bar4{fill:var(--red)}
.logo-svg .line{stroke:var(--yellow)}
.logo-svg .tri{fill:var(--yellow)}
.logo-svg .lbl{fill:var(--red)}
.logo-svg rect.bg{fill:var(--bg2);stroke:var(--border);stroke-width:0.5}

/* ── LOGIN SCREEN ── */
#scr-login{background:var(--bg);min-height:100vh;align-items:stretch}
.login-hero{padding:60px 28px 32px;background:var(--bg2);border-bottom:1px solid var(--border);position:relative;overflow:hidden;box-shadow:var(--shadow)}
.login-logo-row{display:flex;align-items:center;gap:16px;margin-bottom:20px}
.login-title{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:3.2rem;letter-spacing:0.05em;line-height:0.9;text-transform:uppercase}
.login-title span{color:var(--red)}
.login-sub{font-family:'IBM Plex Mono',monospace;font-size:0.65rem;color:var(--muted);letter-spacing:0.18em;text-transform:uppercase;margin-top:6px;border-left:2px solid var(--red);padding-left:8px}
.login-tagline{font-family:'IBM Plex Mono',monospace;font-size:0.72rem;color:var(--text2);letter-spacing:0.05em;margin-top:16px;line-height:1.6}
.login-body{flex:1;padding:28px 24px 48px;display:flex;flex-direction:column;gap:0}
.login-tabs{display:flex;gap:0;margin-bottom:24px;border:1px solid var(--border);border-radius:8px;overflow:hidden}
.login-tab{flex:1;padding:12px;text-align:center;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem;letter-spacing:0.06em;text-transform:uppercase;color:var(--muted);background:var(--bg2);transition:all 0.2s;cursor:pointer}
.login-tab.on{background:var(--red);color:#fff}
.lform{display:flex;flex-direction:column;gap:14px}
.lform.hidden{display:none}
.lfg{display:flex;flex-direction:column;gap:7px}
.lfg label{font-family:'IBM Plex Mono',monospace;font-size:0.62rem;color:var(--text2);letter-spacing:0.12em;text-transform:uppercase;font-weight:500}
.lfi{width:100%;padding:14px 16px;background:var(--bg3);border:1px solid var(--border);border-radius:8px;font-size:1rem;color:var(--text);transition:border-color 0.15s;-webkit-appearance:none;appearance:none}
.lfi:focus{border-color:rgba(232,56,13,0.5);background:var(--bg2)}
.lfi::placeholder{color:var(--muted)}
.lbtn-primary{width:100%;padding:16px;background:var(--red);border-radius:8px;color:#fff;font-size:1.05rem;font-weight:700;letter-spacing:0.04em;font-family:'Barlow',sans-serif;margin-top:6px;transition:opacity 0.15s}
.lbtn-primary:active{opacity:0.8}
.lbtn-primary:disabled{opacity:0.4;cursor:not-allowed}
.lerr{background:rgba(232,56,13,0.08);border:1px solid rgba(232,56,13,0.3);border-radius:6px;padding:10px 14px;font-size:0.82rem;color:var(--red);font-family:'IBM Plex Mono',monospace;line-height:1.5;display:none}
.linfo{background:rgba(46,204,113,0.08);border:1px solid rgba(46,204,113,0.25);border-radius:6px;padding:10px 14px;font-size:0.82rem;color:var(--green);font-family:'IBM Plex Mono',monospace;line-height:1.6;display:none}
.lpw-hint{font-size:0.7rem;color:var(--muted);font-family:'IBM Plex Mono',monospace;padding-left:2px}
.forgot-link{font-size:0.78rem;color:var(--text2);font-family:'IBM Plex Mono',monospace;text-align:right;cursor:pointer;padding:4px 0;text-decoration:underline;text-underline-offset:3px}
.forgot-link:active{color:var(--red)}

/* ── HOME ── */
.hdr{padding:52px 20px 18px;background:var(--bg2);border-bottom:1px solid var(--border);position:relative;box-shadow:var(--shadow)}
.hdr::after{content:'';position:absolute;bottom:-1px;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--red),var(--red2),transparent);opacity:0.6}
.hdr-row{display:flex;align-items:center;gap:14px}
.wordmark .title{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:2.8rem;letter-spacing:0.05em;line-height:0.9;text-transform:uppercase;color:var(--text)}
.wordmark .title span{color:var(--red)}
.wordmark .sub{font-family:'IBM Plex Mono',monospace;font-size:0.6rem;color:var(--muted);letter-spacing:0.18em;text-transform:uppercase;margin-top:5px;border-left:2px solid var(--red);padding-left:8px}
.hdr-date{font-family:'IBM Plex Mono',monospace;font-size:0.68rem;color:var(--text2);margin-top:13px;letter-spacing:0.06em}
.hdr-user-badge{position:absolute;top:14px;right:60px;display:flex;align-items:center;gap:8px;cursor:pointer;padding:6px 10px;border-radius:20px;background:var(--bg3);border:1px solid var(--border);transition:border-color 0.15s}
.hdr-user-badge:hover{border-color:var(--red)}
.hdr-avatar{width:28px;height:28px;border-radius:50%;object-fit:cover;border:2px solid var(--red)}
.hdr-avatar-svg{width:28px;height:28px;border-radius:50%;border:2px solid var(--red);background:var(--bg4);display:flex;align-items:center;justify-content:center;font-size:1rem;overflow:hidden}
.hdr-email{font-family:'IBM Plex Mono',monospace;font-size:0.6rem;color:var(--text2);max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

.ulist{padding:14px 16px 8px;flex:1;display:flex;flex-direction:column;gap:10px}
.ucard{border-radius:8px;border:1px solid var(--border);border-left:4px solid var(--muted);background:var(--bg2);overflow:hidden;box-shadow:var(--shadow)}
.ucard.ok{border-left-color:var(--green)}
.ucard.nope{border-left-color:var(--red);background:rgba(232,56,13,0.02)}
.ucard-main{display:flex;justify-content:space-between;min-height:84px;cursor:pointer}
.ucard-l{padding:14px 15px;flex:1}
.ucard-n{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.8rem;letter-spacing:0.04em;text-transform:uppercase;line-height:1;display:flex;align-items:center;gap:8px}
.ucard-avatar{width:22px;height:22px;border-radius:50%;border:1.5px solid currentColor;display:inline-flex;align-items:center;justify-content:center;font-size:0.8rem;overflow:hidden;flex-shrink:0;vertical-align:middle}
.ucard-m{font-family:'IBM Plex Mono',monospace;font-size:0.65rem;color:var(--text2);margin-top:6px;line-height:1.7}
.trend-arrow{font-size:1.1rem;display:inline-block}
.nope-badge{display:inline-flex;align-items:center;gap:6px;margin-top:8px;padding:6px 10px;background:rgba(232,56,13,0.08);border-radius:4px;border:1px solid rgba(232,56,13,0.2)}
.nope-txt{font-family:'IBM Plex Mono',monospace;font-size:0.62rem;color:var(--red);letter-spacing:0.05em;line-height:1.5}
.ok-badge{display:inline-flex;align-items:center;gap:6px;margin-top:8px;padding:6px 10px;background:rgba(30,163,90,0.08);border-radius:4px;border:1px solid rgba(30,163,90,0.2)}
.ok-txt{font-family:'IBM Plex Mono',monospace;font-size:0.62rem;color:var(--green);letter-spacing:0.05em;line-height:1.5}
.ucard-r{padding:14px 15px;background:var(--bg3);border-left:1px solid var(--border);display:flex;flex-direction:column;justify-content:center;align-items:flex-end;min-width:115px}
.ucard-w{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:3rem;line-height:1}
.ucard-w .u{font-size:1.1rem;font-weight:400;opacity:0.4}
.ucard-w.none{font-size:0.95rem;font-weight:700;color:var(--red);line-height:1.35;text-align:right}
.ucard-d{font-family:'IBM Plex Mono',monospace;font-size:0.68rem;margin-top:4px}
.ucard-d.g{color:var(--green)}
.ucard-d.b{color:var(--red)}
.ucard-target{font-family:'IBM Plex Mono',monospace;font-size:0.6rem;margin-top:3px;color:var(--text2)}
.qrow{display:flex;gap:8px;padding:10px 14px;border-top:1px solid var(--border);background:var(--bg3)}
.qi{flex:1;padding:9px 12px;background:var(--bg2);border:1px solid var(--border2);border-radius:6px;color:var(--text);font-size:0.95rem}
.qbtn{padding:9px 16px;background:var(--red);border-radius:6px;color:#fff;font-weight:700;font-size:0.85rem;letter-spacing:0.04em}
.krow{display:flex;gap:6px;padding:8px 14px;border-top:1px solid var(--border);flex-wrap:wrap;align-items:center}
.klbl{font-family:'IBM Plex Mono',monospace;font-size:0.58rem;color:var(--muted);letter-spacing:0.08em;margin-right:2px}
.kbtn{padding:6px 11px;border-radius:5px;background:var(--bg3);border:1px solid var(--border);color:var(--text2);font-size:0.8rem;font-weight:500;transition:all 0.15s}
.kbtn:active{background:rgba(212,160,23,0.15);border-color:var(--yellow);color:var(--yellow)}
.hactions{padding:12px 16px 30px;display:flex;gap:8px;flex-wrap:wrap}
.btn-add{flex:1;padding:13px;border-radius:6px;border:1px dashed var(--border2);color:var(--muted);font-size:0.9rem;font-weight:600;min-width:140px}
.btn-logout{padding:13px 16px;border-radius:6px;background:rgba(232,56,13,0.06);border:1px solid rgba(232,56,13,0.2);color:var(--red);font-size:0.85rem;font-weight:600}

/* ── GROUP BANNER ── */
.group-banner{margin:12px 16px 0;background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:12px 15px;display:flex;align-items:center;justify-content:space-between;box-shadow:var(--shadow)}
.group-name{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.4rem;letter-spacing:0.06em;text-transform:uppercase;color:var(--red)}
.group-btns{display:flex;gap:6px}
.group-btn{padding:7px 12px;border-radius:6px;background:var(--bg3);border:1px solid var(--border);color:var(--text2);font-size:0.75rem;font-weight:600;cursor:pointer}

/* ── CHART INLINE ── */
.chart-inline{padding:0 16px 10px;margin-top:6px}
.cbox{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:15px;margin-bottom:12px;box-shadow:var(--shadow)}
.cleg{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:10px}
.cli{display:flex;align-items:center;gap:6px;font-size:0.72rem;color:var(--text2);font-family:'IBM Plex Mono',monospace}
.cld{width:10px;height:10px;border-radius:50%}
svg.ch{width:100%;overflow:visible}
.chart-filter-row{display:flex;gap:6px;margin-bottom:10px;overflow-x:auto;padding-bottom:3px}
.fb{padding:7px 14px;border-radius:20px;border:1px solid var(--border);color:var(--text2);font-size:0.72rem;white-space:nowrap;font-family:'IBM Plex Mono',monospace;flex-shrink:0;transition:all 0.15s;font-weight:500;background:var(--bg3);cursor:pointer}
.fb.on{background:var(--red);border-color:var(--red);color:#fff}

/* ── USER DETAIL ── */
.uhero{padding:52px 20px 20px;background:var(--bg2);border-bottom:1px solid var(--border);box-shadow:var(--shadow)}
.back{padding:7px 14px;border-radius:20px;background:var(--bg3);border:1px solid var(--border);color:var(--text2);font-size:0.82rem;margin-bottom:14px;cursor:pointer}
.uname{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:3.2rem;letter-spacing:0.04em;text-transform:uppercase;line-height:1;display:flex;align-items:center;gap:12px}
.uname-avatar{width:44px;height:44px;border-radius:50%;border:3px solid currentColor;display:flex;align-items:center;justify-content:center;font-size:1.5rem;overflow:hidden;flex-shrink:0}
.hstats{display:flex;gap:7px;margin-top:12px;flex-wrap:wrap}
.hs{background:var(--bg3);border:1px solid var(--border);border-radius:6px;padding:9px 12px;flex:1;min-width:70px}
.hs-l{font-family:'IBM Plex Mono',monospace;font-size:0.55rem;color:var(--muted);letter-spacing:0.1em;text-transform:uppercase}
.hs-v{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.4rem;line-height:1.2;margin-top:2px}
.ubody{padding:15px 18px 50px}
.stitle{font-family:'IBM Plex Mono',monospace;font-size:0.6rem;color:var(--muted);letter-spacing:0.16em;text-transform:uppercase;margin:20px 0 10px;padding-left:2px}
.wi-card{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:15px;box-shadow:var(--shadow)}
.wi-l{font-size:0.85rem;color:var(--text2);margin-bottom:10px}
.wi-row{display:flex;gap:8px}
.wi-i{flex:1;padding:12px 13px;background:var(--bg3);border:1px solid var(--border2);border-radius:6px;color:var(--text);font-size:1.1rem}
.wi-b{padding:12px 18px;background:var(--red);border-radius:6px;color:#fff;font-weight:700;font-size:0.95rem}
.pbar-wrap{margin-top:12px}
.pbar-lbls{display:flex;justify-content:space-between;font-family:'IBM Plex Mono',monospace;font-size:0.63rem;color:var(--text2);margin-bottom:5px}
.pbar{height:6px;background:var(--bg4);border-radius:99px;overflow:hidden}
.pbar-fill{height:100%;border-radius:99px;background:linear-gradient(90deg,var(--red),var(--red2));transition:width 0.6s}
.ccard{background:var(--bg2);border:1px solid var(--border);border-radius:8px;overflow:hidden;box-shadow:var(--shadow)}
.crow{display:flex;justify-content:space-between;align-items:center;padding:11px 15px;border-bottom:1px solid var(--border);font-size:0.88rem}
.crow:last-child{border-bottom:none;background:rgba(232,56,13,0.04)}
.cl{color:var(--text2)}
.cv{font-family:'IBM Plex Mono',monospace;font-size:0.85rem;color:var(--text)}
.crow:last-child .cl{font-weight:700;color:var(--red);font-size:0.92rem}
.crow:last-child .cv{font-weight:700;color:var(--red);font-size:0.95rem}
.rcard{background:var(--bg2);border:1px solid var(--border);border-radius:8px;overflow:hidden;box-shadow:var(--shadow)}
.rrow{display:flex;justify-content:space-between;align-items:center;padding:12px 15px;border-bottom:1px solid var(--border)}
.rrow:last-child{border-bottom:none}
.rt{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.8rem;color:var(--red);line-height:1}
.rl{font-size:0.8rem;color:var(--text2);margin-top:2px}
.rl-sub{font-size:0.72rem;color:var(--muted);font-family:'IBM Plex Mono',monospace;margin-top:1px}
.tog{width:48px;height:28px;border-radius:14px;background:var(--bg4);border:1px solid var(--border);position:relative;cursor:pointer;transition:background 0.2s;flex-shrink:0}
.tog.on{background:var(--green);border-color:var(--green)}
.tog::after{content:'';position:absolute;top:3px;left:3px;width:20px;height:20px;border-radius:50%;background:#fff;transition:transform 0.2s;box-shadow:0 1px 4px rgba(0,0,0,0.3)}
.tog.on::after{transform:translateX(20px)}
.lrow{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border)}
.ld{font-family:'IBM Plex Mono',monospace;font-size:0.68rem;color:var(--text2)}
.lkg{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.5rem;line-height:1}
.ldiff{font-family:'IBM Plex Mono',monospace;font-size:0.68rem}

/* ── PROFILE SCREEN ── */
#scr-profile{padding:52px 20px 80px;background:var(--bg)}
.profile-hero{display:flex;flex-direction:column;align-items:center;gap:14px;margin-bottom:28px;padding:24px;background:var(--bg2);border:1px solid var(--border);border-radius:12px;box-shadow:var(--shadow)}
.profile-avatar-big{width:80px;height:80px;border-radius:50%;border:3px solid var(--red);display:flex;align-items:center;justify-content:center;font-size:2.5rem;overflow:hidden;cursor:pointer;position:relative}
.profile-avatar-big img{width:100%;height:100%;object-fit:cover}
.profile-avatar-overlay{position:absolute;inset:0;background:rgba(0,0,0,0.4);display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity 0.2s;border-radius:50%}
.profile-avatar-big:hover .profile-avatar-overlay{opacity:1}
.avatar-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin:12px 0}
.av-opt{width:100%;aspect-ratio:1;border-radius:50%;border:2px solid var(--border);font-size:1.6rem;display:flex;align-items:center;justify-content:center;cursor:pointer;background:var(--bg3);transition:border-color 0.15s}
.av-opt.sel{border-color:var(--red)}

/* ── COLOR PICKER ── */
.color-picker-wrap{margin:10px 0}
.color-spectrum{width:100%;height:36px;border-radius:6px;cursor:crosshair;position:relative;background:linear-gradient(to right,#e8380d,#f5c518,#2ecc71,#4fc3f7,#ea80fc,#ff6040,#e8380d);border:1px solid var(--border)}
.color-handle{width:18px;height:18px;border-radius:50%;border:2px solid #fff;position:absolute;top:50%;transform:translateY(-50%);margin-left:-9px;box-shadow:0 1px 4px rgba(0,0,0,0.4);transition:left 0.05s}
.color-preview{width:32px;height:32px;border-radius:50%;border:2px solid var(--border2);margin:0 auto;flex-shrink:0}

/* ── GROUP MANAGEMENT ── */
#scr-group{padding:52px 20px 80px;background:var(--bg)}
.group-card{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:16px;margin-bottom:12px;box-shadow:var(--shadow)}
.gc-title{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.6rem;text-transform:uppercase;letter-spacing:0.04em;margin-bottom:10px}
.invite-link-box{background:var(--bg3);border:1px solid var(--border);border-radius:6px;padding:10px 14px;font-family:'IBM Plex Mono',monospace;font-size:0.7rem;word-break:break-all;color:var(--text2);margin:8px 0;cursor:pointer;transition:background 0.15s}
.invite-link-box:active{background:var(--bg4)}
.member-row{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid var(--border)}
.member-row:last-child{border-bottom:none}
.mem-avatar{width:32px;height:32px;border-radius:50%;border:2px solid;display:flex;align-items:center;justify-content:center;font-size:1rem;overflow:hidden;flex-shrink:0}
.mem-info{flex:1}
.mem-name{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem;text-transform:uppercase;letter-spacing:0.04em}
.mem-email{font-family:'IBM Plex Mono',monospace;font-size:0.6rem;color:var(--muted)}
.mem-vis{font-family:'IBM Plex Mono',monospace;font-size:0.6rem;color:var(--text2);margin-top:2px}
.mem-badge{padding:4px 8px;border-radius:12px;font-family:'IBM Plex Mono',monospace;font-size:0.58rem;border:1px solid var(--border);color:var(--text2);background:var(--bg3)}

/* ── ADD USER ── */
#scr-add{padding:52px 20px 80px;background:var(--bg)}
.atitle{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:2.6rem;letter-spacing:0.04em;text-transform:uppercase;margin-bottom:5px}
.asub{font-size:0.88rem;color:var(--text2);margin-bottom:22px;line-height:1.6}
.fg{margin-bottom:13px}
.fg label{display:block;font-family:'IBM Plex Mono',monospace;font-size:0.62rem;color:var(--text2);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:7px;font-weight:500}
.fi{width:100%;padding:12px 14px;background:var(--bg2);border:1px solid var(--border);border-radius:6px;font-size:0.95rem;color:var(--text);transition:border-color 0.15s}
.fi:focus{border-color:rgba(232,56,13,0.5);background:var(--bg2)}
select.fi{background:var(--bg2)}
select.fi option{background:var(--bg2);color:var(--text)}
.fgrow{display:flex;gap:10px}
.fgrow .fg{flex:1}
.fhint{font-size:0.7rem;color:var(--muted);margin-top:4px;line-height:1.5}
.cprev{background:rgba(232,56,13,0.05);border:1px solid rgba(232,56,13,0.2);border-radius:8px;padding:13px 15px;margin:14px 0;font-size:0.8rem;line-height:2.3;font-family:'IBM Plex Mono',monospace;color:var(--text2);display:none}
.cprev span{color:var(--red2);font-weight:600}
.bmr-warn{background:rgba(245,165,23,0.08);border:1px solid rgba(245,165,23,0.3);border-radius:6px;padding:10px 14px;font-size:0.78rem;color:var(--yellow);font-family:'IBM Plex Mono',monospace;line-height:1.6;margin-top:6px;display:none}
.bp{width:100%;padding:15px;background:var(--red);border-radius:6px;color:#fff;font-size:1rem;font-weight:700;margin-bottom:10px;letter-spacing:0.04em;font-family:'Barlow',sans-serif}
.bs{width:100%;padding:12px;background:var(--bg3);border:1px solid var(--border);border-radius:6px;color:var(--text2);font-size:0.9rem;font-weight:500;font-family:'Barlow',sans-serif}
.del-btn{width:100%;margin-top:20px;padding:12px;border-radius:6px;background:rgba(232,56,13,0.06);border:1px solid rgba(232,56,13,0.2);color:var(--red);font-size:0.9rem;font-weight:600;font-family:'Barlow',sans-serif;cursor:pointer}

/* ── NOTIFICATIONS ── */
#nwrap{position:fixed;top:0;left:0;right:0;z-index:9995;display:flex;flex-direction:column}
.notif{padding:14px 20px 14px 16px;border-bottom:2px solid var(--red);display:flex;align-items:flex-start;gap:12px;animation:sdn 0.35s ease;position:relative}
@keyframes sdn{from{transform:translateY(-100%);opacity:0}to{transform:translateY(0);opacity:1}}
.notif.base{background:linear-gradient(135deg,rgba(232,56,13,0.08),rgba(232,56,13,0.15))}
.notif.mile{background:linear-gradient(135deg,rgba(30,163,90,0.08),rgba(30,163,90,0.15));border-bottom-color:var(--green)}
.notif.kudo{background:linear-gradient(135deg,rgba(212,160,23,0.08),rgba(212,160,23,0.15));border-bottom-color:var(--yellow)}
.ni{font-size:1.4rem;flex-shrink:0;margin-top:2px}
.nb{flex:1}
.nt{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.1rem;letter-spacing:0.06em;color:var(--red);text-transform:uppercase}
.notif.mile .nt{color:var(--green)}
.notif.kudo .nt{color:var(--yellow)}
.nm{font-size:0.82rem;color:var(--text2);margin-top:3px;line-height:1.5}
.nx{color:var(--muted);font-size:1.1rem;cursor:pointer;padding:2px 5px;flex-shrink:0}
.empty{text-align:center;color:var(--muted);padding:40px 0;font-size:0.9rem;line-height:2.2}

/* Loading */
.spin-wrap{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;gap:16px}
.spin{width:40px;height:40px;border:3px solid var(--border2);border-top-color:var(--red);border-radius:50%;animation:spin 0.8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.spin-txt{font-family:'IBM Plex Mono',monospace;font-size:0.75rem;color:var(--muted);letter-spacing:0.1em}

/* ── PC LAYOUT (wider screens) ── */
@media(min-width:768px){
