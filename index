  if(isMyProfile) {
    privHtml = `<div style="background:var(--bg2);border:1px solid var(--border);border-radius:8px;overflow:hidden">
      <div style="padding:12px 15px;border-bottom:1px solid var(--border)">
        <div style="font-family:'IBM Plex Mono',monospace;font-size:0.6rem;color:var(--muted);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:10px">Wer kann meine Daten sehen?</div>
        <div style="display:flex;gap:6px;flex-wrap:wrap">
          ${[{v:'all',icon:'🌍',label:'Alle Member'},{v:'selected',icon:'👥',label:'Bestimmte'},{v:'private',icon:'🔒',label:'Nur ich'}].map(opt=>`
            <button onclick="setPrivMode('${opt.v}')" style="flex:1;min-width:80px;padding:10px 8px;border-radius:6px;border:1px solid ${ps.mode===opt.v?'rgba(232,56,13,0.6)':'var(--border)'};background:${ps.mode===opt.v?'rgba(232,56,13,0.1)':'var(--bg3)'};color:${ps.mode===opt.v?'var(--red)':'var(--text2)'};font-size:0.82rem;font-weight:600;font-family:Barlow,sans-serif;cursor:pointer">${opt.icon}<br><span style="font-size:0.72rem">${opt.label}</span></button>`).join('')}
        </div>
      </div>
      ${ps.mode==='selected'&&others.length?`<div style="padding:12px 15px">
        <div style="font-family:'IBM Plex Mono',monospace;font-size:0.58rem;color:var(--muted);letter-spacing:0.1em;text-transform:uppercase;margin-bottom:8px">Sichtbar für:</div>
        ${others.map(o=>`<div class="rrow" style="padding:9px 0">
          <div style="font-size:0.9rem">${o.name}</div>
          <div class="tog ${(ps.allowed||[]).includes(o.id)?'on':''}" onclick="toggleAllowed('${o.id}')"></div>
        </div>`).join('')}
      </div>`:''}
    </div>`;
  } else {
    const modeLabel = {all:'🌍 Für alle sichtbar',selected:'👥 Eingeschränkt sichtbar',private:'🔒 Privat'}[ps.mode]||'';
    privHtml = `<div style="font-size:0.85rem;color:var(--muted);padding:8px 0">${modeLabel}</div>`;
  }
  document.getElementById('upriv').innerHTML = privHtml;

  // User chart (soll/ist only here)
  renderUserChart();

  // Log
  const logEl = document.getElementById('ulog');
  if(!log.length) { logEl.innerHTML = `<div class="empty">Noch keine Einträge.</div>`; return; }
  logEl.innerHTML = [...log].reverse().map((e,i,arr) => {
    const prev = arr[i+1];
    const d = prev ? parseFloat((e.w - prev.w).toFixed(1)) : null;
    const ep = e.date.split('-').map(Number);
    const dateObj = new Date(ep[0], ep[1], ep[2]);
    const dateDisp = dateObj.toLocaleDateString('de-DE',{day:'2-digit',month:'2-digit',year:'numeric'});
    return `<div class="lrow">
      <div class="ld">${dateDisp}</div>
      <div style="display:flex;align-items:center;gap:12px">
        ${d!==null?`<div class="ldiff" style="color:${d<=0?'var(--green)':'var(--red)'}">${d>0?'+':''}${d} kg</div>`:''}
        <div class="lkg">${e.w}<span style="font-size:0.8rem;opacity:0.4"> kg</span></div>
      </div></div>`;
  }).join('');
}

function renderUserChart() {
  const wrap = document.getElementById('user-chart-wrap');
  const u = getUser(uid); if(!u) return;
  const i = getUsers().findIndex(x => x.id === uid);
  const col = getUserColor(u, i);
  const log = getLog(uid);
  if(!log.length) { wrap.innerHTML = `<div class="empty">Noch keine Daten.</div>`; return; }

  let dates = [...new Set(log.map(e=>e.date))].sort((a,b)=>{const pa=a.split('-').map(Number),pb=b.split('-').map(Number);return pa[0]-pb[0]||pa[1]-pb[1]||pa[2]-pb[2];});

  const W=360,H=160,PT=16,PB=36,PL=40,PR=16;
  const allW = [...log.map(e=>e.w), u.gKg, u.sKg];
  let mn = Math.floor((Math.min(...allW)-0.5)*2)/2;
  let mx = Math.ceil((Math.max(...allW)+0.5)*2)/2;
  const xi = i => PL + (i/Math.max(dates.length-1,1))*(W-PL-PR);
  const yi = v => PT + (mx-v)/(mx-mn)*(H-PT-PB);

  let svg = '';
  for(let w=mn;w<=mx;w+=0.5){
    const y=yi(w);
    if(y<PT-2||y>H-PB+2)continue;
    svg+=`<line x1="${PL}" y1="${y}" x2="${W-PR}" y2="${y}" stroke="${w%1===0?'rgba(0,0,0,0.07)':'rgba(0,0,0,0.03)'}" stroke-width="${w%1===0?1:0.5}"/>`;
    if(w%1===0)svg+=`<text x="${PL-4}" y="${y+4}" fill="var(--muted)" font-size="9" text-anchor="end" font-family="IBM Plex Mono,monospace">${w}</text>`;
  }
  const dateIdxs = dates.length<=6?dates.map((_,i)=>i):[0,Math.floor(dates.length/3),Math.floor(2*dates.length/3),dates.length-1];
  dateIdxs.forEach(i=>{
    if(!dates[i])return;
    const p=dates[i].split('-').map(Number);const d=new Date(p[0],p[1],p[2]);
    svg+=`<text x="${xi(i)}" y="${H-3}" fill="var(--muted)" font-size="8.5" text-anchor="middle" font-family="IBM Plex Mono,monospace">${String(d.getDate()).padStart(2,'0')}.${String(d.getMonth()+1).padStart(2,'0')}</text>`;
  });

  // Soll-Kurve
  const tp=dates.map((d,i)=>{const p=d.split('-').map(Number);return{x:xi(i),y:yi(targetW(u,new Date(p[0],p[1],p[2])))};});
  if(tp.length>1){let t=`M${tp[0].x},${tp[0].y}`;tp.forEach(p=>t+=` L${p.x},${p.y}`);svg+=`<path d="${t}" fill="none" stroke="${col}" stroke-width="1.5" stroke-dasharray="5 4" opacity="0.4"/>`;}

  const pts=log.map(e=>{const idx=dates.indexOf(e.date);if(idx<0)return null;const p=e.date.split('-').map(Number);const targ=targetW(u,new Date(p[0],p[1],p[2]));return{x:xi(idx),y:yi(e.w),w:e.w,targ};}).filter(Boolean);
  if(pts.length>1){
    for(let i=1;i<pts.length;i++){const p0=pts[i-1],p1=pts[i];const segCol=p1.w<=p1.targ?'var(--green)':'var(--red)';const cx=(p0.x+p1.x)/2;svg+=`<path d="M${p0.x},${p0.y} C${cx},${p0.y} ${cx},${p1.y} ${p1.x},${p1.y}" fill="none" stroke="${segCol}" stroke-width="2.5" stroke-linecap="round"/>`;}
  }
  pts.forEach((p,i)=>{const last=i===pts.length-1;const dotCol=p.w<=p.targ?'var(--green)':'var(--red)';svg+=`<circle cx="${p.x}" cy="${p.y}" r="${last?5:3}" fill="${dotCol}" stroke="var(--bg2)" stroke-width="2"/>`;if(last)svg+=`<text x="${p.x+7}" y="${p.y+4}" fill="${dotCol}" font-size="9.5" font-weight="bold" font-family="IBM Plex Mono,monospace">${p.w}</text>`;});

  // Abs Day marker
  const userAbsDay=absDay(u);
  const absDateIdx=dates.indexOf(`${userAbsDay.getFullYear()}-${userAbsDay.getMonth()}-${userAbsDay.getDate()}`);
  if(absDateIdx>=0){const ax=xi(absDateIdx);svg+=`<line x1="${ax}" y1="${PT}" x2="${ax}" y2="${H-PB}" stroke="var(--red)" stroke-width="1.5" stroke-dasharray="3 3" opacity="0.6"/>`;svg+=`<text x="${ax+3}" y="${PT+10}" fill="var(--red)" font-size="9" font-family="Barlow Condensed,sans-serif" font-weight="800" letter-spacing="0.5">ABS DAY</text>`;}

  wrap.innerHTML = `<div class="cbox">
    <div class="cleg">
      <div class="cli"><div class="cld" style="background:${col}"></div><span>${u.name}</span></div>
      <div class="cli"><div style="width:18px;height:2px;border-top:2px dashed ${col};opacity:0.5"></div><span style="opacity:0.6">Sollkurve</span></div>
      <div class="cli"><div class="cld" style="background:var(--green)"></div><span>Unter Soll</span></div>
      <div class="cli"><div class="cld" style="background:var(--red)"></div><span>Über Soll</span></div>
    </div>
    <svg class="ch" viewBox="0 0 ${W} ${H}" style="max-height:200px">${svg}</svg>
  </div>`;
}

// Privacy actions
window.setPrivMode = function(mode) {
  const s = getPrivSettings(uid); s.mode = mode;
  setPrivSettings(uid, s); renderUser();
};
window.toggleAllowed = function(otherId) {
  const s = getPrivSettings(uid);
  const arr = s.allowed||[];
  s.allowed = arr.includes(otherId) ? arr.filter(x=>x!==otherId) : [...arr,otherId];
  setPrivSettings(uid, s); renderUser();
};

// Save weight (supports comma)
window.saveWeight = function() {
  const raw = document.getElementById('wii').value;
  const v = parseWeight(raw);
  if(isNaN(v) || v < 20 || v > 400) { alert('Bitte ein gültiges Gewicht eingeben (z.B. 82,4).'); return; }
  logW(uid, v);
  document.getElementById('wii').value = '';
  renderUser(); renderHome();
};

window.togRem = function(k) {
  const rem = LS.get(`tmf_rem_${uid}`,{r1:true,r2:true,r3:true,r4:true});
  rem[k] = !rem[k]; LS.set(`tmf_rem_${uid}`, rem); renderUser();
};

window.reqNotifPerm = function() {
  Notification.requestPermission().then(p => {
    if(p==='granted') notif('base','Benachrichtigungen aktiviert!','Du erhältst jetzt Reminders.');
    renderUser();
  });
};

window.addCustomReminder = function() {
  const time = prompt('Uhrzeit für Reminder (HH:MM):');
  if(!time) return;
  const m = time.match(/^(\d{1,2}):(\d{2})$/);
  if(!m) { alert('Bitte im Format HH:MM eingeben.'); return; }
  const label = prompt('Bezeichnung:') || 'Eigener Reminder';
  const custom = LS.get(`tmf_custrem_${uid}`, []);
  const k = `rc_${Date.now()}`;
  custom.push({k, h:parseInt(m[1]), m:parseInt(m[2]), l:label});
  LS.set(`tmf_custrem_${uid}`, custom);
  // add to rem
  const rem = LS.get(`tmf_rem_${uid}`,{r1:true,r2:true,r3:true,r4:true});
  rem[k] = true; LS.set(`tmf_rem_${uid}`, rem);
  renderUser();
};

window.delUser = function(id) {
  const u = getUser(id); if(!u) return;
  if(!confirm(`Profil "${u.name}" wirklich löschen?`)) return;
  saveUsers(getUsers().filter(u => u.id !== id));
  localStorage.removeItem(ukey(`tmf_l_${id}`));
  showHome();
};

// ── Add User ──
window.calcAdd = function() {
  const n = document.getElementById('fn').value.trim();
  const a = parseFloat(document.getElementById('fa').value)||0;
  const h = parseFloat(document.getElementById('fh').value)||0;
  const s = parseWeight(document.getElementById('fs').value)||0;
  const g = parseWeight(document.getElementById('fg2').value)||0;
  const gen = document.getElementById('fgen').value;
  const sp = parseFloat(document.getElementById('fsp').value)||0;
  const int_ = document.getElementById('fint').value;
  const st = parseFloat(document.getElementById('fst').value)||0;
  const targetDate = document.getElementById('ftargetdate').value;

  const el = document.getElementById('cprev');
  const warnEl = document.getElementById('bmr-warn');

  if(!n||!a||!h||!s||!g) { el.style.display='none'; warnEl.style.display='none'; return; }

  let weeks = 13;
  if(targetDate) {
    const msLeft = new Date(targetDate) - new Date();
    weeks = Math.max(1, Math.round(msLeft / (7*86400000)));
  }

  const d2 = {age:a,h,sKg:s,gKg:g,weeks,gen,sport:sp,int:int_,steps:st,curKg:s};
  const b2=bmr(d2),sp2=sportKcal(d2),st2=stepKcal(d2),td=b2+sp2+st2,df=deficit(d2),bud=Math.max(1200,td-df);

  el.style.display = 'block';
  el.innerHTML = `BMR (Mifflin): <span>${b2} kcal</span>  +  Sport: <span>+${sp2}</span>  +  Schritte: <span>+${st2}</span><br>TDEE: <span>${td} kcal/Tag</span>  →  Defizit: <span>−${df} kcal</span><br>🎯 Tagesbudget: <span>${bud} kcal</span>  ·  Abnehmen: <span>${((s-g)/weeks).toFixed(2)} kg/Woche</span><br>Wochen: <span>${weeks}</span>${targetDate?`  ·  Abs-Day: <span>${new Date(targetDate).toLocaleDateString('de-DE')}</span>`:''}`;

  const warn = bmrWarning(d2);
  warnEl.style.display = warn ? 'block' : 'none';
  if(warn) warnEl.textContent = warn;
};

window.createUser = function() {
  const n = document.getElementById('fn').value.trim();
  const a = parseFloat(document.getElementById('fa').value);
  const h = parseFloat(document.getElementById('fh').value);
  const s = parseWeight(document.getElementById('fs').value);
  const g = parseWeight(document.getElementById('fg2').value);
  const gen = document.getElementById('fgen').value;
  const sp = parseFloat(document.getElementById('fsp').value)||0;
  const int_ = document.getElementById('fint').value;
  const st = parseFloat(document.getElementById('fst').value)||0;
  const targetDate = document.getElementById('ftargetdate').value;

  if(!n||isNaN(a)||isNaN(h)||isNaN(s)||isNaN(g)) { alert('Bitte alle Pflichtfelder ausfüllen.'); return; }
  if(s <= g) { alert('Startgewicht muss größer als Zielgewicht sein.'); return; }
  if(s < 30 || s > 400 || g < 30 || g > 400) { alert('Bitte reale Gewichtswerte eingeben.'); return; }

  let weeks = 13;
  if(targetDate) {
    const msLeft = new Date(targetDate) - new Date();
    weeks = Math.max(1, Math.round(msLeft / (7*86400000)));
  }

  const id = 'u' + Date.now();
  const us = getUsers();
  const prof = getProfile(currentUser?.uid);
  us.push({id, name:n, age:a, h, sKg:s, gKg:g, weeks, gen, sport:sp, int:int_, steps:st, curKg:s, targetDate:targetDate||null, created:new Date().toISOString(), firebaseUid:currentUser?.uid||null, color:prof.color||'#e8380d', avatar:prof.avatar||'🙂'});
  saveUsers(us);

  if('Notification' in window && Notification.permission === 'default') Notification.requestPermission();

  showHome();
  startListeners();
};

// Make global
Object.assign(window, {showHome, showAdd, showUser, showProfile, showGroup, ql, sendKudos, saveWeight, togRem, delUser, calcAdd, createUser, setPrivMode, toggleAllowed, copyInviteLink, setF, renderUserChart});
</script>
