      </div>
      ${quickRow}
      ${others.length ? `<div class="krow" onclick="event.stopPropagation()">
        <span class="klbl">Kudos:</span>
        ${others.map(o=>`<button class="kbtn" onclick="sendKudos('${o.id}','${u.id}','🔥')">🔥 ${o.name}</button>
        <button class="kbtn" onclick="sendKudos('${o.id}','${u.id}','💪')">💪</button>
        <button class="kbtn" onclick="sendKudos('${o.id}','${u.id}','👑')">👑</button>`).join('')}
      </div>` : ''}
    </div>`;
  }).join('');

  renderInlineChart();
  renderGroupBanner();
}

function ql(id) {
  const inp = document.getElementById(`qi${id}`);
  if(!inp?.value) return;
  const v = parseWeight(inp.value); if(isNaN(v)) return;
  logW(id, v); inp.value=''; renderHome();
}

// ── Render inline home chart (group overview) ──
function renderInlineChart() {
  const wrap = document.getElementById('chart-inline');
  const users = getUsers();
  if(!users.length) { wrap.innerHTML=''; return; }

  const myId = myUserId();

  // Build filter UI
  const filterHtml = `<div class="chart-filter-row" id="home-cfilt">
    <button class="fb ${cfilter==='all'?'on':''}" onclick="setF('all')">ALLE (Gruppe)</button>
    ${users.map((u,i)=>`<button class="fb ${cfilter===u.id?'on':''}" onclick="setF('${u.id}')" style="${cfilter===u.id?`background:${getUserColor(u,i)};border-color:${getUserColor(u,i)}`:''}">${getUserColor(u,i)?'':''}<span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:${getUserColor(u,i)};margin-right:4px"></span>${u.name}</button>`).join('')}
  </div>`;

  // In "all" mode: show individual curves + thick group sum curve
  // In single user mode: show individual curve with target line (soll/ist)
  const isSingle = cfilter !== 'all';

  let dates = [];
  const visibleUsers = isSingle ? users.filter(u => u.id === cfilter) : users;
  const logs = visibleUsers.map((u,i) => ({u, c:getUserColor(u,i), log:getLog(u.id)})).filter(x => x.log.length);

  if(!logs.length) {
    wrap.innerHTML = filterHtml + `<div class="cbox"><div style="text-align:center;padding:30px;color:var(--muted);font-size:0.9rem">Noch keine Gewichtsdaten</div></div>`;
    return;
  }

  logs.forEach(({log}) => log.forEach(e => dates.push(e.date)));
  dates = [...new Set(dates)].sort((a,b) => {
    const pa = a.split('-').map(Number), pb = b.split('-').map(Number);
    return pa[0]-pb[0] || pa[1]-pb[1] || pa[2]-pb[2];
  });

  const W=360, PT=16, PB=36, PL=40, PR=16;

  // Y axis: 0.5 kg steps — dynamic height based on data range
  let allW = [];
  logs.forEach(({log,u}) => { allW.push(...log.map(e=>e.w)); allW.push(u.gKg, u.sKg); });
  let mn = Math.floor((Math.min(...allW)-1) * 2) / 2;
  let mx = Math.ceil((Math.max(...allW)+1) * 2) / 2;
  // Flexible height: at least 140px, grows with range (12px per 0.5 kg step)
  const rangeSteps = Math.round((mx - mn) / 0.5);
  const H = Math.max(140, Math.min(420, PT + PB + rangeSteps * 14));

  const xi = i => PL + (i / Math.max(dates.length-1,1)) * (W-PL-PR);
  const yi = v => PT + (mx-v)/(mx-mn) * (H-PT-PB);

  let svg = '';

  // Grid lines every 0.5 kg
  const step = 0.5;
  for(let w = mn; w <= mx; w += step) {
    const y = yi(w);
    if(y < PT-2 || y > H-PB+2) continue;
    svg += `<line x1="${PL}" y1="${y}" x2="${W-PR}" y2="${y}" stroke="${w%1===0?'rgba(0,0,0,0.08)':'rgba(0,0,0,0.04)'}" stroke-width="${w%1===0?1:0.5}"/>`;
    if(w%1===0) svg += `<text x="${PL-4}" y="${y+4}" fill="var(--muted)" font-size="9" text-anchor="end" font-family="IBM Plex Mono,monospace">${w}</text>`;
  }

  // X axis: dates
  const dateIdxs = dates.length <= 6 ? dates.map((_,i)=>i) : [0, Math.floor(dates.length/4), Math.floor(dates.length/2), Math.floor(3*dates.length/4), dates.length-1];
  dateIdxs.forEach(i => {
    if(!dates[i]) return;
    const p = dates[i].split('-').map(Number);
    const d = new Date(p[0], p[1], p[2]);
    svg += `<text x="${xi(i)}" y="${H-3}" fill="var(--muted)" font-size="8.5" text-anchor="middle" font-family="IBM Plex Mono,monospace">${String(d.getDate()).padStart(2,'0')}.${String(d.getMonth()+1).padStart(2,'0')}</text>`;
  });

  // In single user view: show target line (soll) + actual (grün/rot)
  // In all view: show each user's actual curve (no soll lines) + group sum thick line
  if(isSingle) {
    logs.forEach(({u, c, log}) => {
      const userAbsDay = absDay(u);
      const absDateStr = userAbsDay.toISOString().slice(0,10);
      
      // Soll-Kurve (dashed, user color)
      const tp = dates.map((d, i) => {
        const p = d.split('-').map(Number);
        return {x: xi(i), y: yi(targetW(u, new Date(p[0], p[1], p[2])))};
      });
      if(tp.length > 1) {
        let t = `M${tp[0].x},${tp[0].y}`;
        tp.forEach(p => t += ` L${p.x},${p.y}`);
        svg += `<path d="${t}" fill="none" stroke="${c}" stroke-width="1.5" stroke-dasharray="5 4" opacity="0.4"/>`;
      }

      // Actual curve (green=below target, red=above)
      const pts = log.map(e => {
        const idx = dates.indexOf(e.date);
        if(idx < 0) return null;
        const p = e.date.split('-').map(Number);
        const targ = targetW(u, new Date(p[0], p[1], p[2]));
        return {x: xi(idx), y: yi(e.w), w: e.w, targ};
      }).filter(Boolean);
      if(pts.length > 1) {
        for(let i=1; i<pts.length; i++) {
          const p0=pts[i-1], p1=pts[i];
          const segCol = p1.w <= p1.targ ? 'var(--green)' : 'var(--red)';
          const cx = (p0.x + p1.x) / 2;
          svg += `<path d="M${p0.x},${p0.y} C${cx},${p0.y} ${cx},${p1.y} ${p1.x},${p1.y}" fill="none" stroke="${segCol}" stroke-width="2.5" stroke-linecap="round"/>`;
        }
      }
      pts.forEach((p, i) => {
        const last = i === pts.length-1;
        const dotCol = p.w <= p.targ ? 'var(--green)' : 'var(--red)';
        svg += `<circle cx="${p.x}" cy="${p.y}" r="${last?5:3}" fill="${dotCol}" stroke="var(--bg2)" stroke-width="2"/>`;
        if(last) svg += `<text x="${p.x+7}" y="${p.y+4}" fill="${dotCol}" font-size="9.5" font-weight="bold" font-family="IBM Plex Mono,monospace">${p.w}</text>`;
      });

      // Abs Day marker (vertical line)
      const absDateIdx = dates.indexOf(`${userAbsDay.getFullYear()}-${userAbsDay.getMonth()}-${userAbsDay.getDate()}`);
      if(absDateIdx >= 0) {
        const ax = xi(absDateIdx);
        svg += `<line x1="${ax}" y1="${PT}" x2="${ax}" y2="${H-PB}" stroke="var(--red)" stroke-width="1.5" stroke-dasharray="3 3" opacity="0.6"/>`;
        svg += `<text x="${ax+3}" y="${PT+10}" fill="var(--red)" font-size="9" font-family="Barlow Condensed,sans-serif" font-weight="800" letter-spacing="0.5">ABS DAY</text>`;
      }
    });
  } else {
    // ALL mode: individual curves (no soll), + group sum thick line
    logs.forEach(({u, c, log}) => {
      const pts = log.map(e => {
        const idx = dates.indexOf(e.date); if(idx < 0) return null;
        return {x: xi(idx), y: yi(e.w), w: e.w};
      }).filter(Boolean);
      if(pts.length > 1) {
        for(let i=1; i<pts.length; i++) {
          const p0=pts[i-1], p1=pts[i];
          const cx = (p0.x+p1.x)/2;
          svg += `<path d="M${p0.x},${p0.y} C${cx},${p0.y} ${cx},${p1.y} ${p1.x},${p1.y}" fill="none" stroke="${c}" stroke-width="2" stroke-linecap="round" opacity="0.8"/>`;
        }
      }
      pts.forEach((p, i) => {
        if(i === pts.length-1) {
          svg += `<circle cx="${p.x}" cy="${p.y}" r="4" fill="${c}" stroke="var(--bg2)" stroke-width="2"/>`;
          svg += `<text x="${p.x+6}" y="${p.y+4}" fill="${c}" font-size="9" font-weight="bold" font-family="IBM Plex Mono,monospace">${p.w}</text>`;
        }
      });
    });

    // Group AVERAGE line (sum of weights / members who entered that day)
    const groupAvgByDate = {};
    const groupTargetAvgByDate = {};
    dates.forEach(d => {
      let sumW = 0, sumT = 0, countW = 0;
      visibleUsers.forEach(u => {
        const log = getLog(u.id);
        const entry = log.find(e => e.date === d);
        const p = d.split('-').map(Number);
        sumT += targetW(u, new Date(p[0], p[1], p[2]));
        if(entry) { sumW += entry.w; countW++; }
      });
      if(countW > 0) {
        groupAvgByDate[d] = sumW / countW;
        groupTargetAvgByDate[d] = sumT / visibleUsers.length;
      }
    });

    const groupDates = dates.filter(d => groupAvgByDate[d] !== undefined);
    if(groupDates.length > 1) {
      // Use same Y axis as individual curves (already calculated)
      const gpts = groupDates.map(d => {
        const idx = dates.indexOf(d);
        return {x: xi(idx), y: yi(groupAvgByDate[d]), actual: groupAvgByDate[d], target: groupTargetAvgByDate[d]};
      });

      for(let i=1; i<gpts.length; i++) {
        const p0=gpts[i-1], p1=gpts[i];
        const col = p1.actual <= p1.target ? 'var(--green)' : 'var(--red)';
        const cx=(p0.x+p1.x)/2;
        svg += `<path d="M${p0.x},${p0.y} C${cx},${p0.y} ${cx},${p1.y} ${p1.x},${p1.y}" fill="none" stroke="${col}" stroke-width="4" stroke-linecap="round" opacity="0.7"/>`;
      }
      // Label
      const last = gpts[gpts.length-1];
      const avgRounded = Math.round(last.actual * 10) / 10;
      svg += `<text x="${last.x-24}" y="${last.y-8}" fill="${last.actual<=last.target?'var(--green)':'var(--red)'}" font-size="9" font-weight="bold" font-family="IBM Plex Mono,monospace">Ø ${avgRounded} kg</text>`;
    }
  }

  const legendHtml = logs.map(({u, c}) => `<div class="cli"><div class="cld" style="background:${c}"></div><span>${u.name}</span></div>`).join('') +
    (isSingle ? `<div class="cli"><div style="width:18px;height:2px;border-top:2px dashed var(--text2);opacity:0.5"></div><span style="opacity:0.5">Sollkurve</span></div>` : `<div class="cli"><div style="width:18px;height:3px;background:linear-gradient(to right,var(--green),var(--red));border-radius:2px"></div><span>Ø Gruppe</span></div>`);

  wrap.innerHTML = filterHtml + `<div class="cbox">
    <div class="cleg">${legendHtml}</div>
    <svg class="ch" viewBox="0 0 ${W} ${H}" style="height:${H}px;max-height:none;width:100%">
      ${svg}
    </svg>
  </div>`;
}

